# ──────────────────────────────────────────────────────────────────────
# fixed-asset-agentic-pro フロントエンド 環境変数テンプレート
# このファイルを .env.local にコピーして使用する:
#   cp .env.example .env.local
# ──────────────────────────────────────────────────────────────────────

# ── バックエンドURL ─────────────────────────────────────────────────────
# FastAPI バックエンド（fixed-asset-ashigaru）のURL
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── クライアントサイド Feature Flag ─────────────────────────────────────
# PDFUploadCard の v1/v2 切替（Section 12）
# false = Phase 1（単一Gemini）/ true = Phase 2（マルチエージェント）
NEXT_PUBLIC_USE_MULTI_AGENT=false

# PDF教師データ取込機能（0:無効, 1:有効）
NEXT_PUBLIC_PDF_TRAINING_ENABLED=1

# ── サーバーサイド Feature Flag ─────────────────────────────────────────
# route.ts でのマルチエージェント有効化（NEXT_PUBLIC_ と揃える）
USE_MULTI_AGENT=false
PARALLEL_AGENTS=true
AUDIT_TRAIL_ENABLED=true
