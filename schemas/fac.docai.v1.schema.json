{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/fac.docai.v1.schema.json",
  "title": "Fixed Assets - DocAI normalized output (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "created_at",
    "source",
    "event",
    "processor",
    "document",
    "annotations",
    "derived",
    "output",
    "errors"
  ],
  "properties": {
    "schema": { "const": "fac.docai.v1" },
    "created_at": { "type": "string", "format": "date-time" },

    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bucket", "name", "generation", "size", "content_type", "sha256"],
      "properties": {
        "bucket": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "generation": { "oneOf": [ { "type": "string" }, { "type": "integer" } ] },
        "size": { "oneOf": [ { "type": "string" }, { "type": "integer" } ] },
        "content_type": { "type": "string", "pattern": "^[a-zA-Z0-9.+-]+/[a-zA-Z0-9.+-]+$" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },

    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ce_type", "ce_id", "ce_source"],
      "properties": {
        "ce_type": { "type": "string", "minLength": 1 },
        "ce_id": { "type": "string", "minLength": 1 },
        "ce_source": { "type": "string", "minLength": 1 }
      }
    },

    "processor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "location", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "location": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },

    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pages", "text_len", "languages"],
      "properties": {
        "pages": { "type": "integer", "minimum": 0 },
        "text_len": { "type": "integer", "minimum": 0 },
        "languages": {
          "type": "array",
          "items": { "type": "string", "minLength": 2 },
          "uniqueItems": true
        }
      }
    },

    "annotations": {
      "type": "array",
      "items": { "$ref": "#/$defs/annotation" }
    },

    "derived": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "invoice_number": { "$ref": "#/$defs/derivedValue" },
        "vendor_name":   { "$ref": "#/$defs/derivedValue" },
        "total_amount":  { "$ref": "#/$defs/derivedValueNumber" },
        "invoice_date":  { "$ref": "#/$defs/derivedValueDate" },
        "currency":      { "$ref": "#/$defs/derivedValue" }
      }
    },

    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bucket", "key"],
      "properties": {
        "bucket": { "type": "string", "minLength": 1 },
        "key":    { "type": "string", "minLength": 1 }
      }
    },

    "errors": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["code", "message"],
            "properties": {
              "code": { "type": "string" },
              "message": { "type": "string" }
            }
          }
        ]
      }
    }
  },

  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{64}$"
    },

    "stringOrNumber": {
      "oneOf": [ { "type": "string" }, { "type": "number" } ]
    },

    "annotation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "text": { "type": "string" },
        "value": {
          "oneOf": [
            { "type": "string" },
            { "type": "number" },
            { "type": "boolean" },
            { "type": "object" },
            { "type": "null" }
          ]
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "page": { "type": "integer", "minimum": 0 },
        "bbox": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" },
            "w": { "type": "number" },
            "h": { "type": "number" },
            "unit": { "type": "string" }
          }
        },
        "meta": {
          "type": "object",
          "description": "catch-all for tool-specific extras",
          "additionalProperties": true
        }
      }
    },

    "derivedValue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value"],
      "properties": {
        "value": { "$ref": "#/$defs/stringOrNumber" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },

    "derivedValueNumber": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value"],
      "properties": {
        "value": { "type": "number" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },

    "derivedValueDate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value"],
      "properties": {
        "value": { "type": "string", "format": "date" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}